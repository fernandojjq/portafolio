# Copia este archivo a `.env` y ajusta si hace falta.
# La URL apunta al Oracle XE del docker-compose (usuario APP_USER).
DATABASE_URL=oracle+oracledb://utpb:utpb2026@localhost:1521/?service_name=XEPDB1

# Llave para firmar JWT. En producción: secreto largo aleatorio, NUNCA en git.
JWT_SECRET=cambia-esta-llave-en-produccion
ACCESS_TOKEN_MINUTOS=15
REFRESH_TOKEN_DIAS=7
